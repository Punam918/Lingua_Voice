# Copy this to .env and fill in values

# ─── STT ─────────────────────────────────────────────────────────────────────
# Whisper model size: tiny | base | small | medium | large-v2 | large-v3
# Larger = more accurate but slower and uses more RAM
WHISPER_MODEL=medium

# Path to fine-tuned Whisper checkpoint (leave empty to use base model)
# Example: ./models/stt/whisper-small-nepali
FINETUNED_MODEL_DIR=

# ─── TTS ─────────────────────────────────────────────────────────────────────
# Path to fine-tuned XTTS-v2 checkpoint (EN/DE/ES/FR; leave empty for pretrained)
# Example: ./models/tts/xtts-english
XTTS_MODEL_DIR=

# Path to fine-tuned MMS-TTS checkpoint for Nepali (leave empty for pretrained)
# Example: ./models/tts/mms-tts-nepali-finetuned
MMS_MODEL_DIR=

# ─── Training ────────────────────────────────────────────────────────────────
# HuggingFace token (required for Mozilla Common Voice download)
# Get yours at: https://huggingface.co/settings/tokens
# Accept CV terms at: https://huggingface.co/datasets/mozilla-foundation/common_voice_11_0
HF_TOKEN=your_token_here

# ─── Deployment ──────────────────────────────────────────────────────────────
# Port for the nginx reverse proxy
PORT=80
